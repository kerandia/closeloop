# --- Database ---
DATABASE_URL=postgresql+asyncpg://closeloop:closeloop@localhost:5432/closeloop

# --- OpenAI (reasoning services) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- ElevenLabs (voice agent; used by Data/Integration workstream) ---
ELEVENLABS_API_KEY=

# --- Feature flags ---
LIVE_VOICE=false
REAL_SEND=false
GHOST_RADAR=false

# --- App ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Twilio WhatsApp (real-time co-pilot channel, L2) ---
# Get these from the Twilio console; join the WhatsApp sandbox for instant testing.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox number
TWILIO_TEMPLATE_SID=                          # optional Content template for outside the 24h window
# REAL_SEND=true                              # flip on to actually send via Twilio (else mock)
