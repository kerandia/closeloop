# --- Database ---
DATABASE_URL=postgresql+asyncpg://closeloop:closeloop@localhost:5432/closeloop

# --- OpenAI (reasoning services) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- ElevenLabs (voice agent; used by Data/Integration workstream) ---
ELEVENLABS_API_KEY=

# --- Feature flags ---
LIVE_VOICE=false
REAL_SEND=false
GHOST_RADAR=false

# --- App ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Twilio (real-time co-pilot: SMS via trial number, WhatsApp via sandbox), L2 ---
# Get these from the Twilio console. SMS works with your trial number directly;
# WhatsApp uses the shared sandbox number (join it from your phone first).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # WhatsApp SANDBOX number (NOT your trial number)
TWILIO_SMS_FROM=                              # your Twilio trial/SMS number, e.g. +15551234567
TWILIO_TEMPLATE_SID=                          # optional Content template for outside the 24h WhatsApp window
# REAL_SEND=true                              # flip on to actually send via Twilio (else mock)

# --- Closing Kit visual agent ---
CLOSING_KIT_MODEL=gpt-4o   # set to a stronger model when available (e.g. gpt-4.5-preview / gpt-5)
# CLOSING_KIT_ENABLED=true
